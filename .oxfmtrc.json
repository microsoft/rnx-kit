{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "trailingComma": "es5",
  "ignorePatterns": ["**/__fixtures__/**", "**/lib/**"],
  "sortImports": {
    "groups": [
      ["builtin", "external"],
      ["internal", "subpath"]
    ],
    "newlinesBetween": false
  },
  "sortPackageJson": true
}
